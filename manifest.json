{
  "manifest_version": 3,
  "name": "Extended Backup Assistant",
  "version": "1.0.0",
  "description": "Chrome扩展备份助手 - 备份、导入和批量安装Chrome扩展程序",
  "permissions": [
    "management",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chrome.google.com/webstore/*",
    "https://dav.jianguoyun.com/*",
    "https://*/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "扩展备份助手",
    "default_width": 520,
    "default_height": 600
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
